# ===================== CORE SETUP =====================
MONGO_URL=mongodb://127.0.0.1:27017/wayza
JWT_SECRET=wayza_secret
FRONTEND_URL=http://localhost:5173

# ===================== SMTP / EMAIL =====================
# For dev/testing, Gmail works. For production, enter Resend/AWS/SendGrid details.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_USER=
EMAIL_PASS=

# ===================== CLOUDINARY IMAGES =====================
# These are required BEFORE production deployment so property images are saved permanently.
# Create a free account at cloudinary.com to get these.
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
